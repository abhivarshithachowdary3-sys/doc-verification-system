# ── Copy this to .env and fill in your values ─────────────────────────────────

# App
APP_NAME="Smart Document Verification API"
DEBUG=false
SECRET_KEY=your-secret-key-here

# Database (SQLite for dev, Postgres for production)
DATABASE_URL=sqlite:///./verification.db
# DATABASE_URL=postgresql://user:password@localhost:5432/docverify

# OCR
TESSERACT_CMD=/usr/bin/tesseract
OCR_CONFIDENCE_THRESHOLD=60.0

# LLM (optional — for LangChain-based extraction enhancement)
OPENAI_API_KEY=sk-...

# Blockchain (leave blank to run in hash-only mode)
WEB3_PROVIDER_URL=http://localhost:8545
CONTRACT_ADDRESS=
DEPLOYER_PRIVATE_KEY=

# External APIs
UIDAI_API_URL=https://stage1.uidai.gov.in/onboardingservice/api/v2
UIDAI_API_KEY=

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Fraud detection
FRAUD_SCORE_THRESHOLD=0.65

# CORS (comma-separated origins)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]
